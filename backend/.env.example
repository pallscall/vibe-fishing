# OpenAI 模型 API Key
OPENAI_API_KEY=
# Anthropic 模型 API Key
ANTHROPIC_API_KEY=
# 自定义模型配置文件路径（JSON 文件）
MODEL_CONFIG_PATH=
# 直接通过环境变量传入模型配置（JSON 字符串）
MODEL_CONFIG_JSON=
# Thread 文件存储路径
THREAD_STORE_PATH=./storage/threads.json
# 上下文最多保留消息条数（非 system）
CHAT_CONTEXT_MAX_MESSAGES=20
# 是否启用自动摘要
CHAT_SUMMARY_ENABLED=true
# 触发摘要的消息条数阈值（非 system）
CHAT_SUMMARY_TRIGGER_MESSAGES=40
# 摘要后保留的最近消息条数（非 system）
CHAT_SUMMARY_KEEP_MESSAGES=12
# Thread 过期清理天数
CHAT_THREAD_TTL_DAYS=7
# 模型请求超时时间（毫秒）
CHAT_REQUEST_TIMEOUT_MS=120000
# 是否启用“思考摘要”（用额外一次请求生成 2-4 条思路摘要）
CHAT_THINKING_SUMMARY_ENABLED=true
# Skills 根目录路径（绝对路径）
SKILLS_PATH=/skills
# Skills 启用状态存储路径
SKILLS_STATE_PATH=./storage/skills_state.json

TAVILY_API_KEY=xxxx