
# Thread 文件存储路径, 绝对路径
THREAD_STORE_PATH={$PWD}/backend/storage/threads.json

# 上下文最多保留消息条数（非 system）
CHAT_CONTEXT_MAX_MESSAGES=20
# 是否启用自动摘要
CHAT_SUMMARY_ENABLED=true
# 触发摘要的消息条数阈值（非 system）
CHAT_SUMMARY_TRIGGER_MESSAGES=40
# 摘要后保留的最近消息条数（非 system）
CHAT_SUMMARY_KEEP_MESSAGES=12
# Thread 过期清理天数
CHAT_THREAD_TTL_DAYS=7
# 模型请求超时时间（毫秒）
CHAT_REQUEST_TIMEOUT_MS=120000
# 是否启用“思考摘要”（用额外一次请求生成 2-4 条思路摘要）
CHAT_THINKING_SUMMARY_ENABLED=true
# Skills 根目录路径，绝对路径
SKILLS_PATH={$PWD}/skills


# Tavily Web Search API Key（web_search 工具会用到；请勿提交真实密钥到公共仓库）
TAVILY_API_KEY=

# 是否启用“每个 thread 独立的 sandbox 目录”路径映射（影响 /tmp/user-data/workspace|uploads|outputs 的分目录策略）
SANDBOX_PER_THREAD=true
# 绝对路径访问更严格（true 时禁止访问 sandbox 目录之外的绝对路径）
SANDBOX_PER_THREAD_STRICT=false
# Sandbox API 地址（不为空时，read_file/write_file/bash 等工具会优先通过 sandbox 服务执行）
SANDBOX_API_URL=http://127.0.0.1:12345
# Sandbox API 请求头（JSON 对象字符串，例如 {"Authorization":"Bearer xxx"}）
SANDBOX_API_HEADERS={}
# Sandbox API 超时（秒）
SANDBOX_API_TIMEOUT_SECONDS=60


# 是否启用“按 thread 创建/销毁 sandbox”的生命周期管理（docker provider）
SANDBOX_PER_THREAD_LIFECYCLE=true
# 生命周期 provider（docker=每个 thread 启动一个 sandbox 容器）
SANDBOX_PROVIDER=docker
# Docker 镜像（需内置并暴露 AIO Sandbox 服务端口）
SANDBOX_DOCKER_IMAGE=ghcr.io/agent-infra/sandbox:latest
# 容器内 AIO Sandbox 服务端口（该镜像默认监听 8080；除非你自定义镜像/端口，否则不要改）
SANDBOX_DOCKER_CONTAINER_PORT=8080
# Docker Host（用于访问 docker 守护进程/端口转发，按你的环境调整）
SANDBOX_DOCKER_HOST=127.0.0.1
# 是否把 storage/threads/... 等数据目录挂载进容器（默认 true；此处注释为可选覆盖）
# SANDBOX_DOCKER_MOUNT_DATA=true
# sandbox 容器命名前缀（便于识别/清理）
# SANDBOX_DOCKER_NAME_PREFIX=vf-sb
# 额外 docker run 参数（JSON 数组字符串）
# SANDBOX_DOCKER_EXTRA_ARGS=["--cpus=2","--memory=4g"]
